{
  "name": "brain-detox",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "typecheck:functions": "tsc --noEmit -p functions/tsconfig.json",
    "secrets:register": "powershell -ExecutionPolicy Bypass -File ./scripts/register-eas-secrets.ps1",
    "secrets:register:force": "powershell -ExecutionPolicy Bypass -File ./scripts/register-eas-secrets.ps1 -Force",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:preview:android": "eas build --profile preview --platform android",
    "build:production:ios": "eas build --profile production --platform ios",
    "build:production:android": "eas build --profile production --platform android",
    "functions:deploy": "npx firebase-tools deploy --only functions",
    "functions:logs": "firebase functions:log",
    "rules:deploy": "npx firebase-tools deploy --only firestore:rules"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "@shopify/react-native-skia": "2.2.12",
    "expo": "~54.0.34",
    "expo-asset": "~12.0.13",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-localization": "~17.0.8",
    "expo-notifications": "~0.32.17",
    "firebase": "^12.12.1",
    "i18next": "^26.0.5",
    "react": "19.1.0",
    "react-i18next": "^17.0.3",
    "react-native": "0.81.5",
    "react-native-chart-kit": "^6.12.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.15.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "typescript": "~5.9.2"
  },
  "private": true
}
