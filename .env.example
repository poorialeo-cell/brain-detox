# ─────────────────────────────────────────────────────────────
# Firebase クライアント設定（公開前提のキー）
# Firebase Console → プロジェクト設定 → 全般 → 「マイアプリ」から取得
# EAS ビルドでは EAS Secrets に登録し、eas.json の env で参照すること
# ─────────────────────────────────────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# OpenAI API キーはサーバー側 (Firebase Functions Secret Manager) で管理
# クライアントには絶対に設定しないこと
# サーバー側のセット方法:
#   npx firebase-tools functions:secrets:set OPENAI_API_KEY
